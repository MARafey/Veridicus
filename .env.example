# LLM Provider: "anthropic", "openai", "ollama", "nvidia", "arliai", or "cerebras"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Ollama (local, no API key needed)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Cerebras (OpenAI-compatible, fast inference)
CEREBRAS_API_KEY=your-cerebras-key
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# ArliAI (OpenAI-compatible)
ARLIAI_API_KEY=your-arliai-key
ARLIAI_MODEL=Mistral-Nemo-12B-Instruct-2407
ARLIAI_BASE_URL=https://api.arliai.com/v1

# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# GitHub (optional but recommended — raises rate limit to 5000 req/hour)
GITHUB_TOKEN=ghp_...

# App
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/veridicus
DOWNLOADS_DIR=./downloads
CORS_ORIGINS=http://localhost:3000

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Resend email (leave blank in dev — invite URLs will be logged to console instead)
RESEND_API_KEY=re_...
RESEND_FROM=noreply@veridicus.ai

# NextAuth / JWT (must match NEXTAUTH_SECRET in frontend/.env.local)
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Public base URL (used in invite email links)
PUBLIC_BASE_URL=http://localhost:3000
