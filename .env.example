# LLM Provider: "anthropic", "openai", "ollama", "nvidia", "arliai", or "cerebras"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Ollama (local, no API key needed)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Cerebras (OpenAI-compatible, fast inference)
CEREBRAS_API_KEY=your-cerebras-key
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# ArliAI (OpenAI-compatible)
ARLIAI_API_KEY=your-arliai-key
ARLIAI_MODEL=Mistral-Nemo-12B-Instruct-2407
ARLIAI_BASE_URL=https://api.arliai.com/v1

# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# GitHub (optional but recommended — raises rate limit to 5000 req/hour)
GITHUB_TOKEN=ghp_...

# App
DATABASE_URL=sqlite:///./polygraph.db
DOWNLOADS_DIR=./downloads
CORS_ORIGINS=http://localhost:3000
